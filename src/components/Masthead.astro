---
interface Props {
  variant?: 'default' | 'home';
  siteTitleHtml?: string;
  homeLocation?: string;
  authorName?: string;
  rightLine?: string;
  leftLine?: string;
  screenLabel?: string;
  lastUpdate?: string;   // formatted date string, home variant only
  subtitle?: string;     // sub-masthead strip, home variant only
}
const {
  variant = 'default',
  siteTitleHtml = 'Site',
  homeLocation = '',
  authorName = 'Author',
  rightLine,
  leftLine,
  screenLabel,
  lastUpdate,
  subtitle = '',
} = Astro.props;
const isHome = variant === 'home';
---
{isHome ? (
  <header
    class="masthead"
    style="border-bottom-width: 4px; border-bottom-style: double; padding-bottom: 18px;"
    data-screen-label={screenLabel}
  >
    <div class="left">{homeLocation}</div>
    <div class="nameplate fade-in" set:html={siteTitleHtml} />
    <div class="right">{lastUpdate ?? ''}</div>
  </header>
) : (
  <header class="masthead" data-screen-label={screenLabel}>
    <div class="left">{leftLine ?? authorName}</div>
    <a class="nameplate" href="/" set:html={siteTitleHtml} />
    <div class="right">{rightLine ?? ''}</div>
  </header>
)}

{isHome && (
  <div class="masthead-sub">
    <span>{subtitle}</span>
  </div>
)}

<style>
  .masthead-sub {
    border-bottom: 1px solid var(--ink);
    padding: 8px clamp(20px, 5vw, 56px);
    text-align: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
</style>
