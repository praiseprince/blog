---
interface Props {
  active?: 'index' | 'archive' | 'desk' | 'friends' | 'about';
}
const { active } = Astro.props;

const links: Array<{ key: NonNullable<Props['active']>; href: string; label: string }> = [
  { key: 'index',   href: '/',         label: 'Index' },
  { key: 'archive', href: '/archive/', label: 'Archive' },
  { key: 'desk',    href: '/desk/',    label: 'Desk' },
  { key: 'friends', href: '/friends/', label: 'Friends' },
];
---
<nav class="sitenav">
  <button
    class="sitenav-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="sitenav-links"
    onclick="const n=this.closest('.sitenav');n.classList.toggle('is-open');this.setAttribute('aria-expanded',n.classList.contains('is-open'));this.textContent=n.classList.contains('is-open')?'Close':'Menu'"
  >Menu</button>
  <div class="sitenav-links" id="sitenav-links">
    {links.map(l => (
      <a href={l.href} class:list={[{ 'is-active': active === l.key }]}>{l.label}</a>
    ))}
    <span class="spacer"></span>
    <a href="/about/" class:list={[{ 'is-active': active === 'about' }]}>About</a>
  </div>
  <button class="theme-toggle" onclick="PP.toggleTheme()">☾ NIGHT</button>
</nav>
