---
interface Props {
  rightHref?: string;
  rightLabel?: string;
  left?: string;
}
const {
  rightHref = '/about/',
  rightLabel = 'About →',
  left = '',
} = Astro.props;
---
<footer class="colophon">
  <div>{left}</div>
  <div class="right">
    <a href="/feed.xml">Feed</a><span class="colophon-sep" aria-hidden="true"> · </span><a href="/sitemap.xml">Sitemap</a><span class="colophon-sep" aria-hidden="true"> · </span><a href={rightHref}>{rightLabel}</a>
  </div>
</footer>
<style>
  .colophon-sep { color: var(--ink-fade); }
</style>
