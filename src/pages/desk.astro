---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCard from '../components/MediaCard.astro';
import Tag from '../components/Tag.astro';
import {
  getAllMedia, groupByKind, groupByStatus,
  SECTION_LABEL, STATUS_LABEL, KIND_ORDER,
  type MediaKind,
} from '../lib/media';
import { getSiteConfig, pageTitle } from '../lib/siteConfig';

const site = getSiteConfig();
const all = await getAllMedia();
const byKind = groupByKind(all);

// Totals for header
const total = all.length;
const counts = {
  book:  byKind.get('book')!.length,
  film:  byKind.get('film')!.length,
  show:  byKind.get('show')!.length,
  album: byKind.get('album')!.length,
  track: byKind.get('track')!.length,
};
const latestMediaDate = new Date(Math.max(
  ...all.map(item => (item.data.lastAt ?? item.data.firstAt)?.getTime() ?? 0),
));
const latestMediaDateLabel = latestMediaDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const sectionGridClass: Record<MediaKind, string> = {
  book:  'grid-books',
  film:  'grid-posters',
  show:  'grid-posters',
  album: 'grid-squares',
  track: 'grid-tracks',
};
---
<BaseLayout
  title={pageTitle('On the desk')}
  description="Books, films, shows, albums and tracks I'm consuming."
  activeNav="desk"
  screenLabel="Desk"
  mastheadRight="The desk"
>
  <main class="page" style="padding-top: clamp(40px, 7vw, 80px);">

    <section class="desk-head">
      <div class="desk-head-main">
        <div class="eyebrow fade-in">The desk · books, films, shows, albums, tracks</div>
        <h1 class="display fade-in-2" style="font-size: clamp(2rem, 6vw, 4.6rem); margin: 14px 0 0; line-height: 1;">
          On the <em>desk,</em> right now.
        </h1>
      </div>
      <div class="desk-head-meta fade-in-3 meta">
        Updated {latestMediaDateLabel}<br/>
        {total} entries · {counts.book} books<br/>
        {counts.film} films · {counts.show} shows · {counts.album} albums
      </div>
    </section>

    <hr class="rule rule-ink" style="margin: 48px 0 0;" />

    <div class="desk-controls" id="desk-controls">
      <div class="filter-bar" role="tablist" aria-label="Filter by kind">
        <button class="is-active" data-kind="all">All — {total}</button>
        <button data-kind="book">Books — {counts.book}</button>
        <button data-kind="film">Films — {counts.film}</button>
        <button data-kind="show">Shows — {counts.show}</button>
        <button data-kind="album">Albums — {counts.album}</button>
        <button data-kind="track">Tracks — {counts.track}</button>
      </div>
      <div class="sort-control">
        <span class="sort-label meta">Sort —</span>
        <div class="sort-menu" id="desk-sort">
          <button
            type="button"
            class="sort-trigger"
            aria-haspopup="listbox"
            aria-expanded="false"
            data-value="default"
          >
            <span class="sort-trigger-label">By status (default)</span>
            <svg class="sort-trigger-chevron" viewBox="0 0 12 8" aria-hidden="true" focusable="false">
              <path d="M1 1 L6 6 L11 1" stroke="currentColor" stroke-width="1.25" fill="none" stroke-linecap="square" stroke-linejoin="miter"/>
            </svg>
          </button>
          <ul class="sort-options" role="listbox" aria-label="Sort entries" tabindex="-1" hidden>
            <li role="option" data-value="default"  aria-selected="true">By status (default)</li>
            <li role="option" data-value="recent"   aria-selected="false">Recently updated</li>
            <li role="option" data-value="az"       aria-selected="false">A → Z</li>
            <li role="option" data-value="rating"   aria-selected="false">Rating ▼</li>
            <li role="option" data-value="revisits" aria-selected="false">Most revisited</li>
            <li role="option" data-value="earliest" aria-selected="false">Earliest first</li>
          </ul>
        </div>
      </div>
    </div>

    {KIND_ORDER.map(kind => {
      const items = byKind.get(kind)!;
      if (items.length === 0) return null;
      const byStatus = groupByStatus(items);
      return (
        <section class="kind-section" data-kind={kind}>
          <header class="kind-header">
            <h2 class="kind-label">{SECTION_LABEL[kind]}</h2>
            <div class="kind-count meta">{items.length} {items.length === 1 ? 'entry' : 'entries'}</div>
          </header>

          {[...byStatus.entries()].map(([status, list]) => (
            <div class="status-group">
              <div class="status-label meta">{STATUS_LABEL[kind][status] ?? status}</div>
              <div class={`media-grid ${sectionGridClass[kind]}`}>
                {list.map(item => <MediaCard item={item} />)}
              </div>
              <nav class="pager status-pager" aria-label="Pagination" hidden></nav>
            </div>
          ))}
        </section>
      );
    })}

    <div class="divider-glyph"></div>

    <blockquote style="max-width: 720px; margin: 24px auto; font-family: var(--font-display); font-style: italic; font-size: clamp(1.4rem, 2.6vw, 2rem); line-height: 1.3; text-align: center; color: var(--ink); padding: 0 24px; border: none;">
      "{site.deskQuote}"
      {site.deskQuoteAuthor && (
        <cite style="font-family: var(--font-mono); font-style: normal; font-size: 11px; letter-spacing: 0.14em; color: var(--ink-fade); text-transform: uppercase; display: block; margin-top: 16px;">— {site.deskQuoteAuthor}</cite>
      )}
    </blockquote>

    <hr class="rule" style="margin: 64px 0 24px;" />

    <aside style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 24px;">
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        <Tag name="reading" />
        <Tag name="film" />
        <Tag name="album" />
      </div>
      <a class="arrow" href="/archive/">See full archive</a>
    </aside>
  </main>

  <script is:inline>
    (function(){
      // Stash each card's original parent so "Default" sort can restore the status-grouped layout
      document.querySelectorAll('.media-card').forEach((card, idx) => {
        const grid = card.parentElement;
        if (!grid.id) grid.id = 'og-grid-' + idx;
        card.dataset.originalParent = grid.id;
      });

      // ─── Numbered pagination, per status group ───
      // Each status sub-grid (Reading now, Finished, …) paginates on its own at
      // 10 per page. When the Sort dropdown flattens a kind, all its cards land
      // in the first grid, so that one pager drives the whole sorted list.
      const PER_PAGE = 10;
      const pagerPages = new Map(); // grid element -> current page

      // Google-style numbered controls: ‹ 1 … 4 5 6 … 20 ›
      function renderControls(mount, current, pages, go) {
        mount.innerHTML = '';
        mount.hidden = pages <= 1;
        if (pages <= 1) return;
        const add = (label, p, o) => {
          o = o || {};
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'pager-btn' + (o.current ? ' is-current' : '') + (o.nav ? ' pager-nav' : '');
          b.textContent = label;
          if (o.disabled) b.disabled = true;
          else if (!o.current) b.addEventListener('click', () => go(p));
          if (o.label) b.setAttribute('aria-label', o.label);
          mount.appendChild(b);
        };
        const ell = () => {
          const s = document.createElement('span');
          s.className = 'pager-ellipsis';
          s.textContent = '…';
          mount.appendChild(s);
        };
        add('‹', current - 1, { nav: true, disabled: current === 1, label: 'Previous page' });
        const want = new Set([1, pages, current, current - 1, current + 1]);
        const list = [...want].filter(n => n >= 1 && n <= pages).sort((a, b) => a - b);
        let prev = 0;
        list.forEach(n => {
          if (n - prev > 1) ell();
          add(String(n), n, { current: n === current });
          prev = n;
        });
        add('›', current + 1, { nav: true, disabled: current === pages, label: 'Next page' });
      }

      function pageGroup(group) {
        const grid = group.querySelector('.media-grid');
        const mount = group.querySelector('.status-pager');
        if (!grid || !mount) return;
        const cards = Array.from(grid.querySelectorAll('.media-card'));
        const pages = Math.max(1, Math.ceil(cards.length / PER_PAGE));
        let page = pagerPages.get(grid) || 1;
        if (page > pages) page = pages;
        pagerPages.set(grid, page);
        const start = (page - 1) * PER_PAGE;
        const end = start + PER_PAGE;
        cards.forEach((c, i) => { c.style.display = (i >= start && i < end) ? '' : 'none'; });
        renderControls(mount, page, pages, p => {
          pagerPages.set(grid, p);
          pageGroup(group);
          const anchor = group.closest('.kind-section') || group;
          anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
      function pageAllGroups() {
        document.querySelectorAll('.status-group').forEach(pageGroup);
      }
      pageAllGroups();

      const sortMenu = document.getElementById('desk-sort');
      const sortTrigger = sortMenu.querySelector('.sort-trigger');
      const sortLabel = sortTrigger.querySelector('.sort-trigger-label');
      const sortOptionsList = sortMenu.querySelector('.sort-options');
      const sortOptions = Array.from(sortOptionsList.querySelectorAll('[role="option"]'));
      const kindButtons = document.querySelectorAll('.desk-controls [data-kind]');

      function comparator(key) {
        return (a, b) => {
          if (key === 'az')       return a.dataset.title.localeCompare(b.dataset.title);
          if (key === 'recent')   return (b.dataset.updated || '').localeCompare(a.dataset.updated || '');
          if (key === 'rating')   return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
          if (key === 'revisits') return parseInt(b.dataset.revisits, 10) - parseInt(a.dataset.revisits, 10);
          if (key === 'earliest') return (a.dataset.first || '9999').localeCompare(b.dataset.first || '9999');
          return 0;
        };
      }

      function applyKindFilter(kind) {
        document.querySelectorAll('.kind-section').forEach(sec => {
          const matches = (kind === 'all') || (sec.dataset.kind === kind);
          sec.style.display = matches ? '' : 'none';
        });
      }

      function applySort(key) {
        const isDefault = key === 'default';
        document.querySelectorAll('.kind-section').forEach(section => {
          const statusGroups = section.querySelectorAll('.status-group');
          const cards = section.querySelectorAll('.media-card');
          if (isDefault) {
            // Restore status-grouped layout
            cards.forEach(card => {
              const og = document.getElementById(card.dataset.originalParent);
              if (og && card.parentElement !== og) og.appendChild(card);
            });
            statusGroups.forEach(g => {
              const label = g.querySelector('.status-label');
              if (label) label.style.display = '';
            });
          } else {
            // Flatten: hide status labels, move all cards into the first grid
            const firstGrid = section.querySelector('.media-grid');
            if (!firstGrid) return;
            const sorted = [...cards].sort(comparator(key));
            sorted.forEach(card => firstGrid.appendChild(card));
            statusGroups.forEach(g => {
              const label = g.querySelector('.status-label');
              if (label) label.style.display = 'none';
            });
          }
          // Reset each sub-grid to page 1, hide now-empty groups, and re-paginate
          statusGroups.forEach(g => {
            const grid = g.querySelector('.media-grid');
            const hasCards = grid && grid.querySelector('.media-card');
            g.style.display = hasCards ? '' : 'none';
            if (grid) pagerPages.set(grid, 1);
            pageGroup(g);
          });
        });
      }

      kindButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          kindButtons.forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          applyKindFilter(btn.dataset.kind);
        });
      });

      // Custom sort dropdown — replaces the native <select> so it matches the design system.
      function openMenu() {
        sortMenu.classList.add('is-open');
        sortTrigger.setAttribute('aria-expanded', 'true');
        sortOptionsList.hidden = false;
        const selected = sortOptions.find(o => o.getAttribute('aria-selected') === 'true') || sortOptions[0];
        focusOption(selected);
        // Move keyboard focus into the listbox so arrow keys / Enter / Esc are received here.
        sortOptionsList.focus();
      }
      function closeMenu(focusTrigger) {
        sortMenu.classList.remove('is-open');
        sortTrigger.setAttribute('aria-expanded', 'false');
        sortOptionsList.hidden = true;
        clearFocused();
        if (focusTrigger) sortTrigger.focus();
      }
      function clearFocused() {
        sortOptions.forEach(o => o.classList.remove('is-focused'));
      }
      function focusOption(opt) {
        clearFocused();
        if (!opt) return;
        opt.classList.add('is-focused');
        opt.scrollIntoView({ block: 'nearest' });
      }
      function selectOption(opt) {
        sortOptions.forEach(o => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
        sortTrigger.dataset.value = opt.dataset.value;
        sortLabel.textContent = opt.textContent.trim();
        applySort(opt.dataset.value);
        closeMenu(true);
      }
      function focusedIndex() {
        return sortOptions.findIndex(o => o.classList.contains('is-focused'));
      }
      function moveFocus(delta) {
        const i = focusedIndex();
        const next = (i < 0 ? 0 : (i + delta + sortOptions.length) % sortOptions.length);
        focusOption(sortOptions[next]);
      }

      sortTrigger.addEventListener('click', () => {
        if (sortMenu.classList.contains('is-open')) closeMenu();
        else openMenu();
      });
      sortTrigger.addEventListener('keydown', e => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openMenu();
        }
      });
      sortOptions.forEach(opt => {
        opt.addEventListener('mouseenter', () => focusOption(opt));
        opt.addEventListener('click', () => selectOption(opt));
      });
      sortOptionsList.addEventListener('keydown', e => {
        if (e.key === 'ArrowDown') { e.preventDefault(); moveFocus(1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); moveFocus(-1); }
        else if (e.key === 'Home') { e.preventDefault(); focusOption(sortOptions[0]); }
        else if (e.key === 'End') { e.preventDefault(); focusOption(sortOptions[sortOptions.length - 1]); }
        else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const i = focusedIndex();
          if (i >= 0) selectOption(sortOptions[i]);
        } else if (e.key === 'Escape' || e.key === 'Tab') {
          closeMenu(e.key === 'Escape');
        }
      });
      document.addEventListener('click', e => {
        if (sortMenu.classList.contains('is-open') && !sortMenu.contains(e.target)) closeMenu();
      });
    })();
  </script>

  <style>
    .desk-controls {
      margin: 24px 0 12px;
      display: flex;
      gap: 18px;
      align-items: center;
      flex-wrap: wrap;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--rule);
    }
    .desk-controls .filter-bar {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
      flex: 1;
    }
    .desk-controls .filter-bar button {
      font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em;
      text-transform: uppercase;
      background: none; border: 1px solid var(--rule); color: var(--ink-soft);
      padding: 6px 10px; cursor: pointer; transition: all .2s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .desk-controls .filter-bar button:hover { color: var(--ink); border-color: var(--ink); }
    .desk-controls .filter-bar button.is-active {
      background: var(--ink); color: var(--paper); border-color: var(--ink);
    }
    .sort-control {
      display: flex; align-items: center; gap: 10px;
      white-space: nowrap;
    }
    .sort-label {
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-fade);
    }
    /* Custom sort dropdown — matches the .filter-bar chip language */
    .sort-menu { position: relative; display: inline-block; }
    .sort-trigger {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      background: none;
      border: 1px solid var(--rule);
      color: var(--ink-soft);
      padding: 6px 12px;
      cursor: pointer;
      white-space: nowrap;
      transition: color .2s, border-color .2s;
      -webkit-tap-highlight-color: transparent;
    }
    .sort-trigger:hover,
    .sort-menu.is-open .sort-trigger,
    .sort-trigger:focus-visible {
      color: var(--ink);
      border-color: var(--ink);
      outline: none;
    }
    .sort-trigger-chevron {
      width: 9px;
      height: 6px;
      flex: 0 0 auto;
      transition: transform .25s cubic-bezier(.2, .7, .2, 1);
    }
    .sort-menu.is-open .sort-trigger-chevron { transform: rotate(180deg); }

    .sort-options {
      position: absolute;
      top: calc(100% + 6px);
      right: 0;
      min-width: 100%;
      margin: 0;
      padding: 6px 0;
      list-style: none;
      background: var(--paper);
      border: 1px solid var(--ink);
      z-index: 10;
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
      box-shadow: 0 12px 32px -14px color-mix(in srgb, var(--ink) 55%, transparent);
      outline: none;
    }
    .sort-options[hidden] { display: none; }
    .sort-options li {
      position: relative;
      padding: 8px 16px 8px 22px;
      white-space: nowrap;
      cursor: pointer;
      transition: background .15s, color .15s;
    }
    .sort-options li:hover,
    .sort-options li.is-focused {
      background: var(--paper-deep);
      color: var(--ink);
    }
    .sort-options li[aria-selected="true"] { color: var(--ink); }
    .sort-options li[aria-selected="true"]::before {
      content: '';
      position: absolute;
      left: 10px;
      top: 50%;
      width: 4px;
      height: 4px;
      background: var(--accent);
      transform: translateY(-50%);
      border-radius: 50%;
    }
    @media (prefers-reduced-motion: reduce) {
      .sort-trigger-chevron { transition: none; }
    }

    @media (max-width: 720px) {
      .desk-controls {
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
        position: relative;
      }
      .desk-controls .filter-bar {
        flex-wrap: nowrap;
        overflow-x: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
        margin: 0 -16px;
        padding: 4px 16px;
        -webkit-overflow-scrolling: touch;
        width: calc(100% + 32px);
        max-width: none;
      }
      .desk-controls .filter-bar::-webkit-scrollbar { display: none; }
      .desk-controls .filter-bar::after {
        content: '';
        flex: 0 0 4px;
      }
      .sort-control { justify-content: flex-start; }
    }

    .desk-head {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: end;
    }
    .desk-head-meta { text-align: right; line-height: 1.7; }
    @media (max-width: 720px) {
      .desk-head { grid-template-columns: 1fr; gap: 16px; }
      .desk-head-meta { text-align: left; }
    }

    .kind-section {
      margin-top: 64px;
      padding-top: 32px;
      border-top: 1px solid var(--rule);
    }
    .kind-section:first-of-type { border-top: 0; }
    .kind-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .kind-label {
      font-family: var(--font-display);
      font-weight: 400;
      font-style: italic;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      line-height: 1;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin: 0;
    }
    .kind-label::before {
      content: '— ';
      color: var(--accent);
      font-style: normal;
    }

    .status-group { margin-top: 28px; }
    .status-group:first-of-type { margin-top: 0; }
    .status-label {
      margin-bottom: 16px;
      padding-bottom: 4px;
      border-bottom: 1px solid var(--rule);
      color: var(--ink-soft);
      font-size: 10.5px;
    }

    .media-grid { display: grid; gap: clamp(20px, 3vw, 36px); }
    .grid-books   { grid-template-columns: repeat(2, 1fr); gap: 56px clamp(32px, 5vw, 80px); }
    .grid-posters { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
    .grid-squares { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
    .grid-tracks  { grid-template-columns: 1fr; gap: 0; }

    @media (max-width: 800px) {
      .grid-books { grid-template-columns: 1fr; gap: 32px; }
    }
    @media (max-width: 720px) {
      .kind-section { margin-top: 40px; padding-top: 24px; }
      .kind-header { margin-bottom: 16px; }
      .status-group { margin-top: 20px; }
      .status-label { font-size: 10px; margin-bottom: 12px; }
    }
    @media (max-width: 600px) {
      .grid-posters { grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .grid-squares { grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .media-grid { gap: 18px; }
    }
    @media (max-width: 420px) {
      .grid-posters { grid-template-columns: 1fr 1fr; }
      .grid-squares { grid-template-columns: 1fr 1fr; }
    }
  </style>
</BaseLayout>
