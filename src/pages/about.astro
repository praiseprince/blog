---
import BaseLayout from '../layouts/BaseLayout.astro';
import { inlineMarkdown, markdownParagraphs, readSiteMarkdown } from '../lib/siteMarkdown';
import { pageTitle } from '../lib/siteConfig';

const about = readSiteMarkdown('about.md');
const lede = markdownParagraphs(about.sections.lede)[0] ?? '';
const bioParagraphs = markdownParagraphs(about.sections.bio);
const codeParagraphs = markdownParagraphs(about.sections.code);
const quote = markdownParagraphs(about.sections.quote)[0] ?? '';
const elsewhereLinks = [
  about.data.email && {
    label: 'Email',
    href: `mailto:${about.data.email}`,
    text: about.data.email,
  },
  about.data.instagramHref && {
    label: 'Instagram',
    href: about.data.instagramHref,
    text: about.data.instagramLabel ?? about.data.instagramHref,
  },
  about.data.githubHref && {
    label: 'GitHub',
    href: about.data.githubHref,
    text: about.data.githubLabel ?? about.data.githubHref,
  },
  about.data.spotifyHref && {
    label: 'Spotify',
    href: about.data.spotifyHref,
    text: about.data.spotifyLabel ?? 'Spotify',
  },
  {
    label: 'RSS feed',
    href: '/feed.xml',
    text: '/feed.xml',
  },
].filter(Boolean);
---
<BaseLayout
  title={pageTitle(about.data.pageTitle ?? 'About this place')}
  activeNav="about"
  screenLabel="About"
  mastheadRight={about.data.mastheadRight ?? 'About this place'}
>
  <main class="page" style="padding-top: clamp(40px, 8vw, 120px); padding-bottom: 80px;">

    <section class="editorial-grid" style="align-items: end;">
      <div style="grid-column: 1 / span 8;">
        <div class="eyebrow fade-in">{about.data.eyebrow ?? 'About this place'}</div>
        <h1 class="display fade-in-2" style="font-size: clamp(2.4rem, 6vw, 5rem); margin: 18px 0 0; line-height: 0.98;" set:html={inlineMarkdown(about.data.headline)} />
      </div>
      <div style="grid-column: 10 / span 3;" class="fade-in-3 meta">
        {about.data.edition}<br/>
        Last revised {about.data.lastRevised}
      </div>
    </section>

    <hr class="rule rule-ink" style="margin: 64px 0 0;" />

    <section class="editorial-grid" style="margin-top: 64px; row-gap: 40px;">
      <figure style="grid-column: 1 / span 4;">
        <div class="thumb" style="aspect-ratio: 4/5;"><img src={about.data.portraitSrc} alt={about.data.portraitAlt ?? ''} /></div>
      </figure>

      <div style="grid-column: 6 / span 7;">
        {lede && (
          <p class="lede dropcap-none" style="font-family: var(--font-display); font-style: italic; font-size: 1.6rem; line-height: 1.4; color: var(--ink-soft); margin: 0 0 1em;" set:html={lede} />
        )}

        {bioParagraphs.map(paragraph => (
          <p style="font-family: var(--font-body); font-size: 17.5px; line-height: 1.65;" set:html={paragraph} />
        ))}

      </div>
    </section>

    <div class="divider-glyph"></div>

    <section class="editorial-grid" style="row-gap: 56px;">

      <div style="grid-column: span 12;">
        <h2 class="display" style="font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; margin: 0; color: var(--ink);">
          How this is put together.
        </h2>
      </div>

      <div style="grid-column: span 4;">
        <div class="smallcaps" style="color: var(--ink-fade);">Typography</div>
        <hr class="rule" style="margin: 12px 0 16px;" />
        <dl style="margin: 0; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.9;">
          <dt style="color: var(--ink-fade);">Display</dt>
          <dd style="margin: 0 0 8px; font-family: var(--font-display); font-style: italic; font-size: 1.4rem;">{about.data.typographyDisplay}</dd>
          <dt style="color: var(--ink-fade);">Reading</dt>
          <dd style="margin: 0 0 8px; font-family: var(--font-body); font-size: 1.2rem;">{about.data.typographyReading}</dd>
          <dt style="color: var(--ink-fade);">Interface</dt>
          <dd style="margin: 0 0 8px; font-family: var(--font-sans); font-size: 0.95rem;">{about.data.typographyInterface}</dd>
          <dt style="color: var(--ink-fade);">Metadata</dt>
          <dd style="margin: 0; font-family: var(--font-mono); font-size: 0.85rem;">{about.data.typographyMetadata}</dd>
        </dl>
      </div>

      <div style="grid-column: span 4;">
        <div class="smallcaps" style="color: var(--ink-fade);">Code</div>
        <hr class="rule" style="margin: 12px 0 16px;" />
        {codeParagraphs.map((paragraph, index) => (
          <p style={`font-family: var(--font-body); font-size: 15px; line-height: 1.6; color: var(--ink-soft); margin: ${index === 0 ? '0' : '12px 0 0'};`} set:html={paragraph} />
        ))}
      </div>

      <div style="grid-column: span 6;">
        <div class="smallcaps" style="color: var(--ink-fade);">Elsewhere</div>
        <hr class="rule" style="margin: 12px 0 16px;" />
        <ul style="list-style: none; padding: 0; margin: 0; font-family: var(--font-body); font-size: 16px; line-height: 1.9;">
          {elsewhereLinks.map(link => (
            <li>{link.label} — <a href={link.href} style="border-bottom: 1px solid var(--accent);">{link.text}</a></li>
          ))}
        </ul>
      </div>

    </section>

    <hr class="rule rule-ink" style="margin: 80px 0 24px;" />

    <p style="text-align: center; font-family: var(--font-display); font-style: italic; font-size: 1.4rem; color: var(--ink-soft); margin: 0;" set:html={quote} />
  </main>

  <style>
    @media (max-width: 800px) {
      .editorial-grid > div[style*="grid-column: 1 / span 8"],
      .editorial-grid > div[style*="grid-column: 10 / span 3"],
      .editorial-grid > figure[style*="grid-column: 1 / span 4"],
      .editorial-grid > div[style*="grid-column: 6 / span 7"],
      .editorial-grid > div[style*="grid-column: span 4"],
      .editorial-grid > div[style*="grid-column: span 6"],
      .editorial-grid > div[style*="grid-column: span 12"] {
        grid-column: 1 / -1 !important;
      }
    }
  </style>
</BaseLayout>
