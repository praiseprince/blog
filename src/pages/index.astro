---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tag from '../components/Tag.astro';
import { getAllPosts, postUrl, kindLabel, getAllTags, type Post } from '../lib/posts';
import { getAllFriends, friendUrl, isTemplate, type Friend } from '../lib/friends';
import { getAllMedia, mediaUrl, type Media } from '../lib/media';
import { readSiteMarkdown } from '../lib/siteMarkdown';
import { getSiteConfig } from '../lib/siteConfig';
import { getPhotoImage } from '../lib/photoImages';

// HOMEPAGE logic:
// 1. `src/site/home.md` controls the manual cover/lead. The ref accepts
//    `post:slug`, `friend:slug`, or a bare slug (defaults to a main post).
// 2. "Latest, all kinds" is chronological across main posts AND friend posts.
//    Main posts default to essay/photo/walk (fragments/technical opt in with
//    `showOnHome`); every (non-template) friend post is eligible regardless of
//    kind.
const HOME_DEFAULT_KINDS = ['essay', 'photo', 'walk'] as const;
const site = getSiteConfig();
const home = readSiteMarkdown('home.md');
const posts = await getAllPosts();
const friends = (await getAllFriends()).filter(f => !isTemplate(f));

type Entry = Post | Friend;
interface HomeItem {
  entry: Entry;
  isFriend: boolean;
  url: string;
  author: string;
  data: Entry['data'];
}
function toItem(entry: Entry, isFriend: boolean): HomeItem {
  return {
    entry,
    isFriend,
    url: isFriend ? friendUrl(entry as Friend) : postUrl(entry as Post),
    author: isFriend ? (entry as Friend).data.author : site.authorShort,
    data: entry.data,
  };
}

function normalizeSlug(ref = '') {
  return ref
    .trim()
    .replace(/^\/?(posts|friends)\//, '')
    .replace(/\/$/, '')
    .replace(/\.(md|mdx)$/, '');
}

// Resolve `coverPost` to a main post or a friend post.
function resolveCover(ref = ''): HomeItem | undefined {
  const raw = ref.trim();
  if (!raw) return undefined;
  const match = raw.match(/^(post|friend):(.+)$/);
  const kind = match ? match[1] : 'post';
  const slug = normalizeSlug(match ? match[2] : raw);
  if (kind === 'friend') {
    const f = friends.find(x => normalizeSlug(x.id) === slug);
    return f ? toItem(f, true) : undefined;
  }
  const p = posts.find(x => normalizeSlug(x.id) === slug);
  return p ? toItem(p, false) : undefined;
}

const appearsOnHome = (post: Post) =>
  (HOME_DEFAULT_KINDS as readonly string[]).includes(post.data.type) || post.data.showOnHome;

const configuredLead = home.data.coverPost ? resolveCover(home.data.coverPost) : undefined;
if (home.data.coverPost && !configuredLead) {
  throw new Error(`src/site/home.md points coverPost at "${home.data.coverPost}", but no published post/friend with that slug exists.`);
}

const postItems = posts.filter(appearsOnHome).map(p => toItem(p, false));
const friendItems = friends.map(f => toItem(f, true));
const combined = [...postItems, ...friendItems]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const lead: HomeItem | undefined =
  configuredLead ?? combined[0] ?? (posts[0] ? toItem(posts[0], false) : undefined);

function leadImage(item: HomeItem | undefined) {
  if (!item) return null;
  const post = item.data;
  if (post.cover) return post.cover;
  if (post.type === 'walk' && post.timeline) {
    const t = post.timeline.find(x => x.image);
    if (t) return { src: t.image!, alt: '', caption: t.caption, ix: t.ix };
  }
  if (post.type === 'photo' && post.gallery && post.gallery.length > 0) {
    const g = post.gallery[0];
    return { src: g.src, alt: g.alt ?? '', caption: g.caption, ix: g.ix };
  }
  return null;
}
const leadCover = leadImage(lead);
const leadCoverImage = leadCover
  ? await getPhotoImage(leadCover.src, {
      widths: [720, 960, 1280, 1600, 2200],
      sizes: '(max-width: 900px) 100vw, 66vw',
      loading: 'eager',
    })
  : null;

// SIDE COLUMN = latest eligible items (posts + friends), excluding the lead
const rest = combined.filter(i => i.url !== lead?.url);
const sidePosts: HomeItem[] = rest.slice(0, 4);

// 3-COL TIER = next 3 eligible items after the side column
const secondTier: HomeItem[] = rest.slice(4, 7);

// LATEST PHOTOS = uniform thumbnail grid from the most recent photo post's gallery
const recentPhoto = posts.slice(0, 6).find(p => p.data.type === 'photo');
const photoThumbs = await Promise.all((recentPhoto?.data.gallery?.slice(0, 6) ?? []).map(async figure => ({
  figure,
  image: await getPhotoImage(figure.src, {
    widths: [240, 360, 520, 720],
    sizes: '(max-width: 420px) 50vw, (max-width: 720px) 33vw, 16vw',
  }),
})));

// CURRENTLY ON THE DESK = up to 4 active media, varied kinds, kind-first then fill
const allMedia = await getAllMedia();
const deskActive: Media[] = [];
const seenKinds = new Set<string>();
for (const m of allMedia.filter(m => m.data.status === 'consuming')) {
  if (!seenKinds.has(m.data.kind)) { deskActive.push(m); seenKinds.add(m.data.kind); }
  if (deskActive.length === 4) break;
}
for (const m of allMedia.filter(m => m.data.status === 'consuming')) {
  if (deskActive.length === 4) break;
  if (!deskActive.includes(m)) deskActive.push(m);
}

// LAST UPDATE = max date across all posts and media (lastAt fallback)
const allDateMs: number[] = [
  ...posts.map(p => p.data.date.getTime()),
  ...allMedia.map(m => (m.data.lastAt ?? m.data.firstAt)?.getTime() ?? 0),
];
const lastUpdate = new Date(Math.max(...allDateMs, 0));
const lastUpdateStr = lastUpdate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});

const tagMap = await getAllTags();
const tags = [...tagMap.keys()];

const leadKindNoun =
  lead?.data.type === 'essay'    ? 'essay' :
  lead?.data.type === 'photo'    ? 'roll' :
  lead?.data.type === 'walk'     ? 'walk' :
  lead?.data.type === 'fragment' ? 'fragments' : 'entry';
---
<BaseLayout
  title={site.siteTitle}
  activeNav="index"
  mastheadVariant="home"
  mastheadLastUpdate={lastUpdateStr}
  mastheadSubtitle={site.siteSubtitle}
  screenLabel="Index"
>
  <main>
    <!-- LEAD + SIDE -->
    <section class="h01-grid">
      {lead && (
        <article class="h01-lead fade-in">
          <div class="eyebrow">{lead.isFriend ? `Friend writing · ${kindLabel(lead.data.type)}` : (lead.data.eyebrow ?? `Issue's lead · ${kindLabel(lead.data.type)}`)}</div>
          <a href={lead.url}>
            <h1 class="h01-lead-headline" set:html={`${lead.data.title}<span style="color: var(--accent);">.</span>`} />
          </a>

          <div style="display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: end; margin-top: 24px;">
            <div class="meta">By {lead.author}<br/>{lead.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}{lead.data.readTime ? ` · ${lead.data.readTime}` : ''}</div>
            {lead.data.excerpt && <p class="caption" style="max-width: 60ch; margin: 0;" set:html={lead.data.excerpt} />}
          </div>

          {leadCover && (
            <a href={lead.url} style="display: block; margin-top: 32px;">
              <figure>
                <img {...(leadCoverImage?.attrs ?? { src: leadCover.src })} alt={leadCover.alt ?? ''} />
                {(leadCover.caption || leadCover.ix) && (
                  <figcaption>
                    {leadCover.ix && <span class="ix">{leadCover.ix}</span>}
                    <span set:html={leadCover.caption ?? ''} />
                  </figcaption>
                )}
              </figure>
            </a>
          )}

          <a class="arrow" href={lead.url} style="margin-top: 24px;">Continue to the {leadKindNoun}</a>
        </article>
      )}

      <aside class="h01-side fade-in-2">
        <div class="eyebrow" style="color: var(--accent);">Latest, all kinds</div>
        <hr class="rule" style="margin: 12px 0 16px;" />
        {sidePosts.map((item, idx) => {
          const p = item;
          const isLast = idx === sidePosts.length - 1;
          const isFirst = idx === 0;
          const base = 'display: block;';
          const styleStr = isFirst
            ? `${base} padding-bottom: 20px; border-bottom: 1px solid var(--rule);`
            : isLast
              ? `${base} padding: 20px 0;`
              : `${base} padding: 20px 0; border-bottom: 1px solid var(--rule);`;
          const fragStyle = p.data.type === 'fragment' ? 'font-style: italic; color: var(--ink-soft);' : '';
          return (
            <a href={p.url} style={styleStr}>
              <div class="meta" style="margin-bottom: 6px;">{p.isFriend ? 'Friend writing · ' : ''}{kindLabel(p.data.type)} · {p.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</div>
              <h3 class="display" style={`font-family: var(--font-display); font-weight: 400; ${fragStyle} font-size: 1.6rem; line-height: 1.1; margin: 0;`} set:html={p.data.title} />
              {p.isFriend && <div class="meta" style="margin-top: 6px; color: var(--accent);">By {p.author}</div>}
              {p.data.excerpt && <p class="caption" style="margin-top: 10px;" set:html={p.data.excerpt} />}
            </a>
          );
        })}
      </aside>
    </section>

    <!-- 3-COL TIER -->
    {secondTier.length > 0 && (
      <section class="h01-row-2">
        <div class="h01-three">
          {secondTier.map(p => (
            <div>
              <div class="meta" style="margin-bottom: 6px; color: var(--accent);">{p.isFriend ? `Friend writing · ${kindLabel(p.data.type)}` : kindLabel(p.data.type)}</div>
              <a href={p.url}>
                <h3 class="display" style="font-family: var(--font-display); font-weight: 400; font-size: 1.7rem; line-height: 1.1; margin: 0 0 12px;" set:html={p.data.title} />
              </a>
              {p.data.excerpt && <p style="font-family: var(--font-body); font-size: 15px; line-height: 1.6; color: var(--ink-soft); margin: 0 0 12px;" set:html={p.data.excerpt} />}
              <div class="meta">{p.isFriend ? `By ${p.author}` : `${kindLabel(p.data.type)}${p.data.readTime ? ` · ${p.data.readTime}` : ''}`}</div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- LATEST PHOTOS — uniform thumbnail grid -->
    {recentPhoto && photoThumbs.length > 0 && (
      <section class="contact-section">
        <div class="contact-head">
          <div>
            <div class="eyebrow" style="color: var(--accent);">Latest photos</div>
            <h2 class="display" style="font-size: clamp(1.6rem, 3vw, 2.4rem); margin: 8px 0 0; font-weight: 400;" set:html={`From ${recentPhoto.data.title}`} />
          </div>
          <a class="arrow" href={postUrl(recentPhoto)}>See the full roll</a>
        </div>

        <div class="contact-grid">
          {photoThumbs.map(({ figure: g, image }) => (
            <a href={postUrl(recentPhoto)}>
              <div class="thumb"><img {...image.attrs} alt={g.alt ?? ''} /></div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ON THE DESK — kind-specific bounded frames -->
    {deskActive.length > 0 && (
      <section class="desk-strip">
        <div class="desk-strip-head">
          <div>
            <div class="eyebrow" style="color: var(--accent);">Currently on the desk</div>
            <h2 class="display" style="font-size: clamp(1.6rem, 3vw, 2.4rem); margin: 8px 0 0; font-weight: 400;"><em>What I've been</em> around.</h2>
          </div>
          <a class="arrow" href="/desk/">See the whole desk</a>
        </div>

        <div class="desk-strip-grid">
          {deskActive.map(m => (
            <a href={mediaUrl(m)} class={`desk-tile desk-tile-${m.data.kind}`}>
              <div class="desk-tile-frame">
                {m.data.kind === 'book' && !m.data.cover ? (
                  <div class={`tile-spine tone-${m.data.tone}`} set:html={(m.data.spine ?? m.data.title).replace(/\n/g, '<br/>')} />
                ) : (
                  m.data.cover && <img src={m.data.cover} alt={m.data.title.replace(/<[^>]+>/g, '')} />
                )}
              </div>
              <div class="desk-tile-meta">
                <div class="desk-kind meta">{m.data.kind}</div>
                <div class="desk-title display" set:html={m.data.title} />
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- TAGS -->
    {tags.length > 0 && (
      <section style="padding: clamp(32px, 4vw, 56px) clamp(20px, 5vw, 56px) 0;">
        <div class="smallcaps" style="color: var(--ink-fade); margin-bottom: 14px;">Browse by topic</div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          {tags.map(t => <Tag name={t} />)}
        </div>
      </section>
    )}
  </main>

  <style>
    .h01-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: clamp(20px, 2.5vw, 36px);
      padding: clamp(32px, 5vw, 64px) clamp(20px, 5vw, 56px);
    }
    .h01-lead { grid-column: 1 / span 8; }
    .h01-side { grid-column: 9 / span 4; border-left: 1px solid var(--rule); padding-left: clamp(20px, 2vw, 32px); }
    .h01-lead-headline {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 7vw, 5.6rem);
      line-height: 0.96;
      letter-spacing: -0.02em;
      margin: 12px 0 0;
    }
    .h01-lead-headline em { font-style: italic; }
    .h01-row-2 { padding: clamp(20px, 3vw, 40px) clamp(20px, 5vw, 56px); border-top: 1px solid var(--ink); }
    .h01-three { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(28px, 3vw, 56px); }
    .h01-three > div { border-right: 1px solid var(--rule); padding-right: clamp(20px, 2vw, 32px); }
    .h01-three > div:last-child { border-right: 0; padding-right: 0; }

    /* Contact sheet: hero + 4 thumbs underneath */
    .contact-section {
      border-top: 1px solid var(--ink);
      padding: clamp(28px, 4vw, 56px) clamp(20px, 5vw, 56px) 0;
    }
    .contact-head {
      display: flex; justify-content: space-between; align-items: end;
      gap: 16px; flex-wrap: wrap; margin-bottom: 24px;
    }
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
    }
    @media (max-width: 720px) { .contact-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 420px) { .contact-grid { grid-template-columns: repeat(2, 1fr); } }

    /* Desk strip: kind-specific cover frames, each with a stable bounded box */
    .desk-strip {
      border-top: 1px solid var(--ink);
      padding: clamp(28px, 4vw, 56px) clamp(20px, 5vw, 56px) 0;
      margin-top: clamp(28px, 4vw, 56px);
    }
    .desk-strip-head {
      display: flex; justify-content: space-between; align-items: end;
      margin-bottom: 24px; gap: 16px; flex-wrap: wrap;
    }
    .desk-strip-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(16px, 2vw, 28px);
    }
    .desk-tile {
      display: flex; flex-direction: column; gap: 12px;
      color: var(--ink); text-decoration: none;
      transition: opacity .2s;
    }
    .desk-tile:hover { opacity: 0.78; }

    .desk-tile-frame {
      aspect-ratio: 2/3;
      position: relative;
      background: var(--paper-deep);
      overflow: hidden;
      border: 1px solid var(--rule);
    }
    .desk-tile-album .desk-tile-frame,
    .desk-tile-track .desk-tile-frame {
      aspect-ratio: 1/1;
    }
    .desk-tile-book .desk-tile-frame,
    .desk-tile-film .desk-tile-frame,
    .desk-tile-show .desk-tile-frame {
      aspect-ratio: 2/3;
    }
    .desk-tile-frame > img {
      position: absolute;
      top: 12px; left: 12px;
      width: calc(100% - 24px);
      height: calc(100% - 24px);
      object-fit: contain;
      display: block;
      transition: transform .6s cubic-bezier(.2, .6, .2, 1);
    }
    .desk-tile:hover .desk-tile-frame > img { transform: scale(1.03); }
    .desk-tile-book .desk-tile-frame > .tile-spine {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .tile-spine {
      width: 100%; height: 100%;
      background: var(--paper-deep);
      position: relative;
      display: flex; align-items: flex-end; justify-content: center;
      font-family: var(--font-display); font-style: italic; font-size: 13px;
      color: var(--ink-soft); padding: 12px 8px; text-align: center; line-height: 1.15;
      overflow: hidden;
    }
    .tile-spine::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 22px; background: var(--accent);
    }
    .tile-spine.tone-2 { background: var(--ink); color: var(--paper); }
    .tile-spine.tone-2::before { background: var(--paper); }
    .tile-spine.tone-3 { background: var(--accent); color: var(--paper); }
    .tile-spine.tone-3::before { background: var(--ink); }
    .tile-spine.tone-4 {
      background: var(--paper); border-color: var(--accent); color: var(--accent);
    }
    .tile-spine.tone-4::before { background: var(--accent); }

    .desk-tile-meta { display: flex; flex-direction: column; gap: 4px; }
    .desk-kind {
      font-family: var(--font-mono); font-size: 10px;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--ink-fade);
    }
    .desk-title {
      font-family: var(--font-display); font-weight: 400;
      font-size: 1.15rem; line-height: 1.2;
    }
    .desk-title em { font-style: italic; }

    @media (max-width: 900px) {
      .h01-lead, .h01-side { grid-column: 1 / -1; }
      .h01-side { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 28px; margin-top: 16px; }
      .h01-three { grid-template-columns: 1fr; }
      .h01-three > div { border-right: 0; padding-right: 0; padding-bottom: 24px; border-bottom: 1px solid var(--rule); }
      .h01-three > div:last-child { border-bottom: 0; padding-bottom: 0; }
      .desk-strip-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 720px) {
      .contact-section, .desk-strip { padding-left: 16px; padding-right: 16px; }
    }
    @media (max-width: 420px) {
      .desk-strip-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
      .desk-title { font-size: 1rem; }
    }
  </style>
</BaseLayout>
