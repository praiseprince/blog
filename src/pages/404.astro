---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Not here — Postcards from Far Away"
  description="The page you were looking for isn't on the desk."
  activeNav="index"
  screenLabel="404"
  mastheadRight="No such page"
  showColophon={false}
>
  <main class="page" style="padding-top: clamp(60px, 10vw, 140px); padding-bottom: 80px;">
    <div class="column" style="text-align: center;">
      <div class="eyebrow fade-in" style="color: var(--accent);">Misdelivered · No such page</div>

      <h1 class="display fade-in-2" style="font-size: clamp(5rem, 18vw, 11rem); margin: 24px 0 0; line-height: 0.9; letter-spacing: -0.03em;">
        <em>404.</em>
      </h1>

      <p class="fade-in-3" style="font-family: var(--font-display); font-style: italic; font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.3; color: var(--ink-soft); margin: 36px auto 0; max-width: 36ch;">
        That page has gone elsewhere — or was never here to begin with.
      </p>

      <p class="caption fade-in-3" style="margin: 20px auto 0; max-width: 44ch;">
        Postcards do get lost in the post. Try one of these instead.
      </p>

      <nav class="not-found-links">
        <a class="arrow" href="/">Back to the index</a>
        <a class="arrow" href="/archive/">Browse the archive</a>
        <a class="arrow" href="/desk/">See the desk</a>
      </nav>

    </div>
  </main>

  <style>
    .not-found-links {
      display: flex;
      gap: 24px;
      justify-content: center;
      margin-top: 56px;
      flex-wrap: wrap;
    }
    @media (max-width: 600px) {
      .not-found-links {
        flex-direction: column;
        gap: 16px;
        align-items: center;
      }
    }
  </style>
</BaseLayout>
