---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import PhotoViewer from '../components/PhotoViewer.astro';
import type { CollectionEntry } from 'astro:content';
import { getSiteConfig, pageTitle } from '../lib/siteConfig';
import { getPhotoImage } from '../lib/photoImages';

interface Props {
  entry: CollectionEntry<'posts'>;
}
const { entry } = Astro.props;
const { data } = entry;
const site = getSiteConfig();
const filedDate = data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const coverImage = data.cover
  ? await getPhotoImage(data.cover.src, {
      widths: [720, 960, 1280, 1600, 2200],
      sizes: '(max-width: 1100px) 100vw, 1100px',
      loading: 'eager',
    })
  : null;
---
<BaseLayout
  title={pageTitle(data.title)}
  description={data.excerpt}
  activeNav="archive"
  showReadProgress
  screenLabel="Essay"
  mastheadRight={`Essay · ${data.readTime ?? '12 min'}`}
>
  <main class="page">
    <article class="column" style="padding-top: clamp(40px, 7vw, 88px);">
      {data.eyebrow && <div class="eyebrow fade-in">{data.eyebrow}</div>}
      <h1 class="display fade-in-2" style="font-size: clamp(2.6rem, 6vw, 4.6rem); margin-top: 18px;" set:html={data.title} />
      <p class="meta fade-in-3" style="margin-top: 24px;">
        Filed {filedDate}{data.location ? ` · ${data.location}` : ''}{data.wordCount ? ` · ${data.wordCount.toLocaleString()} words` : ''}
      </p>
      <div class="tick-rule fade-in-3" style="margin-top: 32px;"></div>
    </article>

    {data.cover && (
      <figure class="fade-in-3" style="max-width: 1100px; margin: 56px auto 0;">
        <button
          class="photo-viewer-trigger photo-viewer-trigger-cover"
          type="button"
          data-full-src={coverImage?.fullSrc ?? data.cover.src}
          data-full-alt={data.cover.alt}
          data-full-caption={data.cover.caption}
          data-full-ix={data.cover.ix}
          aria-label="View full image"
        >
          <img {...(coverImage?.attrs ?? { src: data.cover.src })} alt={data.cover.alt} />
        </button>
        {(data.cover.caption || data.cover.ix) && (
          <figcaption>
            {data.cover.ix && <span class="ix">{data.cover.ix}</span>}
            <span set:html={data.cover.caption ?? ''} />
          </figcaption>
        )}
      </figure>
    )}

    <article class="column prose fade-in-4" style="margin-top: 72px;">
      {data.lede && <p class="lede dropcap-none" set:html={data.lede} />}
      <slot />
      <p style="text-align: center; margin-top: 56px;" class="meta">— {site.authorShort}</p>
    </article>

    <aside class="column" style="margin-top: 96px;">
      <hr class="rule rule-ink" />
      <div class="editorial-grid" style="margin-top: 24px;">
        <div style="grid-column: span 4;">
          <div class="smallcaps" style="color: var(--ink-fade);">Filed Under</div>
          <div style="margin-top: 12px; display: flex; flex-wrap: wrap; gap: 8px;">
            {data.tags.map(t => <Tag name={t} />)}
          </div>
        </div>
        {data.cited && data.cited.length > 0 && (
          <div style="grid-column: span 4;">
            <div class="smallcaps" style="color: var(--ink-fade);">Cited</div>
            <ol style="margin: 12px 0 0; padding-left: 18px; font-family: var(--font-body); font-size: 14px; color: var(--ink-soft); line-height: 1.55;">
              {data.cited.map(c => (
                <li>{c.author} — <em>{c.title}</em>{c.year ? `, ${c.year}` : ''}.</li>
              ))}
            </ol>
          </div>
        )}
        {data.nextHref && (
          <div style="grid-column: span 4;">
            <div class="smallcaps" style="color: var(--ink-fade);">Next</div>
            <a href={data.nextHref} style="display: block; margin-top: 12px;">
              <div class="display" style="font-size: 1.25rem; line-height: 1.2;" set:html={data.nextLabel ?? 'Next entry'} />
              <div class="meta" style="margin-top: 6px;">Continue →</div>
            </a>
          </div>
        )}
      </div>
    </aside>

    <PhotoViewer />
  </main>

  <style>
    @media (max-width: 800px) {
      .prose figure[style*="margin: 56px -80px"] { margin-left: 0 !important; margin-right: 0 !important; }
    }
    @media (max-width: 720px) {
      .editorial-grid > div { grid-column: 1 / -1 !important; }
    }
  </style>
</BaseLayout>
