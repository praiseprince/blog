---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'posts'>;
}
const { entry } = Astro.props;
const { data } = entry;
const dateStr = data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout
  title={`${data.title} — Postcards from Far Away`}
  description={data.excerpt}
  activeNav="archive"
  screenLabel="Photo"
  mastheadRight={`Photographs${data.roll ? ` · Roll №${data.roll}` : ''}`}
>
  <main>
    <section style="position: relative; padding: clamp(40px, 6vw, 80px) clamp(20px, 5vw, 56px) 0;">
      <div class="editorial-grid" style="align-items: end;">
        <div style="grid-column: 1 / span 7;">
          {data.eyebrow && <div class="eyebrow fade-in">{data.eyebrow}</div>}
          <h1 class="display fade-in-2" style="font-size: clamp(2.8rem, 7vw, 5.6rem); margin: 16px 0 0;" set:html={data.title} />
          {data.excerpt && <p class="caption fade-in-3" style="margin-top: 24px; max-width: 36ch;" set:html={data.excerpt} />}
        </div>
        <div style="grid-column: 9 / span 4; text-align: right;" class="meta fade-in-3">
          {data.location ?? ''}<br/>
          {data.coords && <>{data.coords}<br/></>}
          {dateStr}
        </div>
      </div>

      {data.cover && (
        <figure class="fade-in-4" style="margin-top: 48px;">
          <button
            class="photo-viewer-trigger photo-viewer-trigger-cover"
            type="button"
            data-full-src={data.cover.src}
            data-full-alt={data.cover.alt}
            data-full-caption={data.cover.caption}
            data-full-ix={data.cover.ix}
            aria-label="View full photograph"
          >
            <img src={data.cover.src} alt={data.cover.alt} />
          </button>
          {(data.cover.caption || data.cover.ix) && (
            <figcaption>
              {data.cover.ix && <span class="ix">{data.cover.ix}</span>}
              <span set:html={data.cover.caption ?? ''} />
            </figcaption>
          )}
        </figure>
      )}
    </section>

    {data.gallery && data.gallery.length > 0 && (
      <section style="padding: 80px clamp(20px, 5vw, 56px) 0;">
        <div class="editorial-grid">
          {data.gallery.map(g => {
            const colstart = g.colstart ?? 1;
            const colspan = g.colspan ?? 12;
            const thumbStyle = [
              g.aspect ? `aspect-ratio: ${g.aspect}` : '',
              g.fit === 'contain' ? 'background: var(--paper-deep)' : '',
            ].filter(Boolean).join('; ');
            const imageStyle = [
              g.fit ? `object-fit: ${g.fit}` : '',
              g.position ? `object-position: ${g.position}` : '',
            ].filter(Boolean).join('; ');
            return (
              <figure style={`grid-column: ${colstart} / span ${colspan};`}>
                <button
                  class="photo-viewer-trigger"
                  type="button"
                  data-full-src={g.src}
                  data-full-alt={g.alt}
                  data-full-caption={g.caption}
                  data-full-ix={g.ix}
                  aria-label="View full photograph"
                >
                  <div class="thumb" style={thumbStyle || undefined}>
                    <img src={g.src} alt={g.alt} style={imageStyle || undefined} />
                  </div>
                </button>
                {(g.caption || g.ix) && (
                  <figcaption>
                    {g.ix && <span class="ix">{g.ix}</span>}
                    <span set:html={g.caption ?? ''} />
                  </figcaption>
                )}
              </figure>
            );
          })}
        </div>
      </section>
    )}

    {data.rollNote && (
      <aside class="column" style="margin-top: 96px;">
        <hr class="rule rule-ink" />
        <div style="display: grid; grid-template-columns: 140px 1fr; gap: 28px; margin-top: 28px; align-items: start;">
          <div class="smallcaps" style="color: var(--ink-fade); padding-top: 4px;">A note on the roll</div>
          <div style="font-family: var(--font-body); font-size: 17px; line-height: 1.6;" set:html={data.rollNote} />
        </div>
        <div style="margin-top: 32px; display: flex; flex-wrap: wrap; gap: 8px;">
          {data.tags.map(t => <Tag name={t} />)}
        </div>
      </aside>
    )}

    <dialog class="photo-viewer" aria-label="Full photograph viewer">
      <button class="photo-viewer-close" type="button" aria-label="Close full photograph">
        <svg class="photo-viewer-close-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M5 5 L19 19 M19 5 L5 19" stroke="currentColor" stroke-width="1.25" stroke-linecap="square" fill="none"/>
        </svg>
        <span class="photo-viewer-close-label">Close</span>
      </button>
      <figure>
        <img alt="" />
        <figcaption>
          <span class="ix"></span>
          <span class="caption"></span>
        </figcaption>
      </figure>
    </dialog>
  </main>

  <style>
    @media (max-width: 720px) {
      .editorial-grid figure { grid-column: 1 / -1 !important; }
    }
  </style>
</BaseLayout>
