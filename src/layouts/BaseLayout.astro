---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';

interface Props {
  title: string;
  description?: string;
  activeNav?: Parameters<typeof SiteNav>[0]['active'];
  mastheadVariant?: 'default' | 'home';
  mastheadRight?: string;
  mastheadLeft?: string;
  mastheadLastUpdate?: string;
  mastheadSubtitle?: string;
  screenLabel?: string;
  showReadProgress?: boolean;
  colophonRightHref?: string;
  colophonRightLabel?: string;
  colophonLeft?: string;
  bodyClass?: string;
  bodyId?: string;
}
const stripHtml = (s: string) => s
  .replace(/<br\s*\/?>/gi, ' ')
  .replace(/<[^>]+>/g, '')
  .replace(/&amp;/g, '&')
  .replace(/&nbsp;/g, ' ')
  .replace(/&shy;/g, '')
  .replace(/\s+/g, ' ')
  .trim();

const {
  title,
  description = 'Postcards from Far Away — a notebook, sometimes.',
  activeNav,
  mastheadVariant = 'default',
  mastheadRight,
  mastheadLeft,
  mastheadLastUpdate,
  mastheadSubtitle,
  screenLabel,
  showReadProgress = false,
  colophonRightHref,
  colophonRightLabel,
  colophonLeft,
  bodyClass,
  bodyId,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={stripHtml(description)} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<title>{stripHtml(title)}</title>
<script src="/script.js" is:inline></script>
<slot name="head" />
</head>
<body class={bodyClass} id={bodyId}>
{showReadProgress && <div class="read-progress"></div>}

<Masthead
  variant={mastheadVariant}
  rightLine={mastheadRight}
  leftLine={mastheadLeft}
  lastUpdate={mastheadLastUpdate}
  subtitle={mastheadSubtitle}
  screenLabel={screenLabel}
/>

<SiteNav active={activeNav} />

<slot />

<Colophon
  rightHref={colophonRightHref}
  rightLabel={colophonRightLabel}
  left={colophonLeft}
/>
</body>
</html>
