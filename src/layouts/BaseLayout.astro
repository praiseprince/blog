---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';
import { getSiteConfig } from '../lib/siteConfig';

interface Props {
  title: string;
  description?: string;
  activeNav?: Parameters<typeof SiteNav>[0]['active'];
  mastheadVariant?: 'default' | 'home';
  mastheadRight?: string;
  mastheadLeft?: string;
  mastheadLastUpdate?: string;
  mastheadSubtitle?: string;
  screenLabel?: string;
  showReadProgress?: boolean;
  colophonRightHref?: string;
  colophonRightLabel?: string;
  colophonLeft?: string;
  showColophon?: boolean;
  bodyClass?: string;
  bodyId?: string;
}
const stripHtml = (s: string) => s
  .replace(/<br\s*\/?>/gi, ' ')
  .replace(/<[^>]+>/g, '')
  .replace(/&amp;/g, '&')
  .replace(/&nbsp;/g, ' ')
  .replace(/&shy;/g, '')
  .replace(/\s+/g, ' ')
  .trim();

const site = getSiteConfig();
const {
  title,
  description = site.siteDescription,
  activeNav,
  mastheadVariant = 'default',
  mastheadRight,
  mastheadLeft,
  mastheadLastUpdate,
  mastheadSubtitle,
  screenLabel,
  showReadProgress = false,
  colophonRightHref,
  colophonRightLabel,
  colophonLeft,
  showColophon = true,
  bodyClass,
  bodyId,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={stripHtml(description)} />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="alternate" type="application/rss+xml" title={site.siteTitle} href="/feed.xml" />
<title>{stripHtml(title)}</title>
<script src="/script.js" is:inline></script>
<slot name="head" />
</head>
<body class={bodyClass} id={bodyId}>
{showReadProgress && <div class="read-progress"></div>}

<Masthead
  variant={mastheadVariant}
  siteTitleHtml={site.siteTitleHtml}
  homeLocation={site.homeLocation}
  authorName={site.authorName}
  rightLine={mastheadRight}
  leftLine={mastheadLeft}
  lastUpdate={mastheadLastUpdate}
  subtitle={mastheadSubtitle}
  screenLabel={screenLabel}
/>

<SiteNav active={activeNav} />

<slot />

{showColophon && (
<Colophon
    rightHref={colophonRightHref}
    rightLabel={colophonRightLabel}
    left={colophonLeft ?? site.authorName}
  />
)}
</body>
</html>
